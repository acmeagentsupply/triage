#!/usr/bin/env bash

# Triage control-plane diagnostic entrypoint
# READ-ONLY MODE: this script must not modify system configuration or service state.
# NO NETWORK CALLS: this script must not initiate outbound network activity or telemetry.
# NO CONFIG MUTATION: this script must not write outside ~/triage-bundles/ proof artifacts.
#
# Safety: read-only • no network • no config writes

set -u

readonly BUNDLE_ROOT="${HOME}/triage-bundles"
readonly SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
readonly VERSION_FILE="${SCRIPT_DIR}/../VERSION"
readonly EMBEDDED_VERSION="0.3.6"   # injected at install time if standalone
readonly COLLECT_TIMEOUT=8          # seconds; applied to each slow command
readonly SESSIONS_TIMEOUT=15        # seconds; sessions API call can be slower on large fleets
readonly INVOKED_NAME="$(basename "${0}")"
OCTU_COLOR_MODE="${OCTU_COLOR_MODE:-auto}"
readonly COLLECTOR_DIR="${SCRIPT_DIR}/../lib/collectors.d"
readonly STATUS_REDUCER="${SCRIPT_DIR}/../lib/status_reduce.sh"

# Ensure standard tool paths are available (macOS + Homebrew)
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH}"

# macOS-compatible timeout wrapper (timeout(1) is GNU coreutils, not in base macOS)
run_timeout() {
  local secs="$1"; shift
  "$@" &
  local child=$!
  ( sleep "${secs}" && kill -TERM "${child}" 2>/dev/null ) &
  local watcher=$!
  wait "${child}" 2>/dev/null
  local rc=$?
  kill "${watcher}" 2>/dev/null
  wait "${watcher}" 2>/dev/null
  return "${rc}"
}

ui_enabled() {
  if [[ "${CLICOLOR_FORCE:-0}" = "1" ]]; then
    OCTU_COLOR_MODE="always"
  fi

  case "${OCTU_COLOR_MODE}" in
    always)
      return 0
      ;;
    never)
      return 1
      ;;
  esac

  [[ -n "${NO_COLOR:-}" ]] && return 1
  [[ "${TERM:-}" = "dumb" ]] && return 1
  return 0
}

color_wrap() {
  local code="$1"
  local text="$2"
  if ui_enabled; then
    printf '\033[%sm%s\033[0m' "${code}" "${text}"
  else
    printf '%s' "${text}"
  fi
}

icon_for_state() {
  local state="${1:-UNKNOWN}"
  case "${state}" in
    OK|HEALTHY|NORMAL|SCHEDULED)
      printf '✓'
      ;;
    WARN*|DEGRADED*|HIGH_ACTIVITY|INCOMPLETE|LOW_CONFIDENCE)
      printf '!'
      ;;
    STALE*|STOPPED*|FAIL*|FANOUT_ANOMALY|CONTRADICTION_DETECTED)
      printf '×'
      ;;
    NOT\ DETECTED|UNKNOWN*)
      printf '·'
      ;;
    *)
      printf '•'
      ;;
  esac
}

color_for_state() {
  local state="${1:-UNKNOWN}"
  case "${state}" in
    OK|HEALTHY|NORMAL|SCHEDULED)
      printf '32'
      ;;
    WARN*|DEGRADED*|HIGH_ACTIVITY|INCOMPLETE|LOW_CONFIDENCE)
      printf '33'
      ;;
    STALE*|STOPPED*|FAIL*|FANOUT_ANOMALY|CONTRADICTION_DETECTED)
      printf '31'
      ;;
    NOT\ DETECTED|UNKNOWN*)
      printf '90'
      ;;
    *)
      printf '36'
      ;;
  esac
}

sha256_file() {
  local target="$1"
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "${target}" | awk '{print $1}'
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "${target}" | awk '{print $1}'
  else
    return 1
  fi
}

json_escape() {
  local input="${1:-}"
  input="${input//\\/\\\\}"
  input="${input//\"/\\\"}"
  input="${input//$'\n'/\\n}"
  input="${input//$'\r'/\\r}"
  input="${input//$'\t'/\\t}"
  printf '%s' "${input}"
}

octu_file_bytes() {
  local target="$1"
  if [[ -f "${target}" ]]; then
    wc -c < "${target}" | tr -d ' '
  else
    printf '0'
  fi
}

octu_sum_file_bytes() {
  local total=0
  local target bytes
  for target in "$@"; do
    [[ -n "${target}" ]] || continue
    bytes="$(octu_file_bytes "${target}")"
    total=$((total + ${bytes:-0}))
  done
  printf '%s' "${total}"
}

octu_artifact_rank() {
  case "${1:-OK}" in
    OK) printf '0' ;;
    PARTIAL) printf '1' ;;
    TIMEOUT_PARTIAL) printf '2' ;;
    TIMEOUT_EMPTY) printf '3' ;;
    PARSE_ERROR) printf '4' ;;
    LOW_CONFIDENCE) printf '5' ;;
    *) printf '6' ;;
  esac
}

octu_worst_artifact_state() {
  local worst="OK"
  local worst_rank state state_rank
  worst_rank="$(octu_artifact_rank "${worst}")"
  for state in "$@"; do
    [[ -n "${state}" ]] || continue
    state_rank="$(octu_artifact_rank "${state}")"
    if (( state_rank > worst_rank )); then
      worst="${state}"
      worst_rank="${state_rank}"
    fi
  done
  printf '%s' "${worst}"
}

octu_confidence_for_artifact_state() {
  case "${1:-OK}" in
    OK) printf 'HIGH' ;;
    PARTIAL|TIMEOUT_PARTIAL) printf 'MEDIUM' ;;
    *) printf 'LOW' ;;
  esac
}

capture_command() {
  local outfile="$1"
  shift

  local exit_code=0
  local timed_out="false"
  local artifact_state="OK"
  local bytes_captured

  : > "${outfile}"
  if run_timeout "${COLLECT_TIMEOUT}" "$@" > "${outfile}" 2>&1; then
    exit_code=0
  else
    exit_code=$?
  fi

  if [[ "${exit_code}" = "124" || "${exit_code}" = "143" ]]; then
    timed_out="true"
  fi

  bytes_captured="$(octu_file_bytes "${outfile}")"
  if [[ "${timed_out}" = "true" ]]; then
    if (( bytes_captured > 0 )); then
      artifact_state="TIMEOUT_PARTIAL"
      printf '\nTIMEOUT after %ss\n' "${COLLECT_TIMEOUT}" >> "${outfile}"
    else
      artifact_state="TIMEOUT_EMPTY"
      printf 'timeout\n' > "${outfile}"
    fi
  elif (( exit_code != 0 )); then
    if (( bytes_captured > 0 )); then
      artifact_state="PARTIAL"
    else
      artifact_state="PARSE_ERROR"
    fi
  elif (( bytes_captured == 0 )); then
    artifact_state="PARTIAL"
  fi

  CAPTURE_EXIT_CODE="${exit_code}"
  CAPTURE_TIMED_OUT="${timed_out}"
  CAPTURE_ARTIFACT_STATE="${artifact_state}"
  CAPTURE_BYTES_CAPTURED="$(octu_file_bytes "${outfile}")"
  return 0
}

redact_secret_stream() {
  python3 -c "$(cat <<'PY'
import re
import sys

patterns = [
    re.compile(
        r'(?P<name>\b[A-Za-z_][A-Za-z0-9_]*(?:'
        r'TOKEN|API[_-]?KEY|ACCESS[_-]?KEY|SECRET|SECRET[_-]?KEY|'
        r'PASSWORD|PASSWD|PASS|AUTH|AUTHORIZATION|BEARER|'
        r'SESSION|COOKIE|CREDENTIALS?|PRIVATE[_-]?KEY|CLIENT[_-]?SECRET'
        r')[A-Za-z0-9_]*\b)'
        r'(?P<sep>\s*(?:=|=>|:)\s*)'
        r'(?P<value>[^\n]*)'
    ),
    re.compile(
        r'(?P<prefix>\bAuthorization\b\s*:\s*Bearer\s+)(?P<value>[^\s,;]+)',
        re.IGNORECASE,
    ),
]

def redact(line: str) -> str:
    def repl_named(match: re.Match[str]) -> str:
        return f"{match.group('name')}{match.group('sep')}[REDACTED]"

    def repl_bearer(match: re.Match[str]) -> str:
        return f"{match.group('prefix')}[REDACTED]"

    line = patterns[0].sub(repl_named, line)
    line = patterns[1].sub(repl_bearer, line)
    return line

for raw_line in sys.stdin:
    sys.stdout.write(redact(raw_line))
PY
)"
}

export -f redact_secret_stream 2>/dev/null || true

octu_write_collector_metadata_file() {
  local outfile="$1"
  local id="$2"
  local script_path="$3"
  local command_name="$4"
  local exit_code="$5"
  local timed_out="$6"
  local bytes_captured="$7"
  local confidence="$8"
  local artifact_state="$9"
  local result_state="${10:-UNKNOWN}"

  cat > "${outfile}" <<EOF
{"id":"$(json_escape "${id}")","script":"$(json_escape "${script_path}")","command":"$(json_escape "${command_name}")","exit_code":${exit_code:-0},"timed_out":${timed_out:-false},"bytes_captured":${bytes_captured:-0},"confidence":"$(json_escape "${confidence:-LOW}")","artifact_state":"$(json_escape "${artifact_state:-LOW_CONFIDENCE}")","result_state":"$(json_escape "${result_state}")"}
EOF
}

render_signal_line() {
  local label="$1"
  local summary="$2"
  local state="${summary%% *}"
  local icon color_code rendered

  case "${summary}" in
    NOT\ DETECTED*) state="NOT DETECTED" ;;
    NOT\ SCHEDULED*) state="STOPPED" ;;
    UNKNOWN*) state="UNKNOWN" ;;
  esac

  icon="$(icon_for_state "${state}")"
  color_code="$(color_for_state "${state}")"
  rendered="$(color_wrap "${color_code}" "${summary}")"

  if ui_enabled; then
    printf '%s %s: %s\n' "$(color_wrap "${color_code}" "${icon}")" "${label}" "${rendered}"
  else
    printf '%s: %s\n' "${label}" "${summary}"
  fi
}

gateway_summary() {
  local health_file="$1/gateway_health.txt"
  local err_file="$1/gateway_err_tail.txt"

  if [[ -f "${health_file}" ]]; then
    if grep -Eiq 'healthy|gateway: ok|status: ok|HTTP 200|connected|ready' "${health_file}"; then
      printf 'OK'
      return 0
    fi
    if grep -Eiq 'degraded|fail|error|timeout|unhealthy|not ok' "${health_file}"; then
      printf 'WARN'
      return 0
    fi
  fi

  if [[ -f "${err_file}" ]]; then
    if grep -Eiq 'not found at ' "${err_file}"; then
      printf 'UNKNOWN'
      return 0
    fi
    if grep -Eiq 'error|failed|timeout|unauthorized|1006|1008|nonce|tailscale|funnel' "${err_file}"; then
      printf 'WARN'
      return 0
    fi
  fi

  printf 'UNKNOWN'
}

sessions_summary() {
  local topology_file="${OCTU_BUNDLE_DIR:-$1}/agent_session_topology.txt"
  local classification agents recent orphan total

  [[ -f "${topology_file}" ]] || {
    printf 'UNKNOWN'
    return 0
  }

  classification="$(awk -F': ' '/^classification:/ {print $2; exit}' "${topology_file}" 2>/dev/null)"
  agents="$(awk -F': ' '/^agents:/ {print $2; exit}' "${topology_file}" 2>/dev/null)"
  recent="$(awk -F': ' '/^sessions_recent:/ {print $2; exit}' "${topology_file}" 2>/dev/null)"
  orphan="$(awk -F': ' '/^orphan_transcripts:/ {print $2; exit}' "${topology_file}" 2>/dev/null)"
  total="$(awk -F': ' '/^sessions_total:/ {print $2; exit}' "${topology_file}" 2>/dev/null)"

  printf '%s (agents=%s recent=%s orphan=%s total=%s)' \
    "${classification:-UNKNOWN}" \
    "${agents:-unknown}" \
    "${recent:-unknown}" \
    "${orphan:-unknown}" \
    "${total:-unknown}"
}

lineage_summary() {
  local topology_file="${OCTU_BUNDLE_DIR:-$1}/agent_session_topology.txt"
  local lineage

  [[ -f "${topology_file}" ]] || {
    printf 'UNKNOWN'
    return 0
  }

  lineage="$(awk -F': ' '/^agent_lineage:/ {print $2; exit}' "${topology_file}" 2>/dev/null)"
  printf '%s' "${lineage:-UNKNOWN}"
}

digest_summary() {
  local digest_path="${HOME}/.openclaw/workspace/DIGEST.md"
  local generated_at
  local stale_flag

  [[ -f "${digest_path}" ]] || {
    printf 'NOT DETECTED'
    return 0
  }

  stale_flag="$(awk -F': ' '/^stale:/ {print $2; exit}' "${digest_path}" 2>/dev/null | tr '[:upper:]' '[:lower:]')"
  generated_at="$(awk -F': ' '/^generated_at_utc:/ {print $2; exit}' "${digest_path}" 2>/dev/null)"

  if [[ "${stale_flag}" = "true" ]]; then
    printf 'STALE'
  elif [[ -n "${generated_at}" ]]; then
    printf 'HEALTHY'
  else
    printf 'UNKNOWN'
  fi
}

builder_summary() {
  local label="gui/$(id -u)/ai.openclaw.digest_builder"
  local launchctl_list
  local launchctl_output
  local last_exit
  local err_log="${HOME}/.openclaw/ops/digest_builder.err.log"

  launchctl_list="$(run_timeout "${COLLECT_TIMEOUT}" launchctl list 2>/dev/null || true)"
  if ! grep -q 'ai\.openclaw\.digest_builder' <<<"${launchctl_list}"; then
    printf 'MISSING/UNLOADED'
    return 0
  fi

  launchctl_output="$(run_timeout "${COLLECT_TIMEOUT}" launchctl print "${label}" 2>/dev/null || true)"
  last_exit="$(awk -F'= ' '/last exit code = / {print $2; exit} /LastExitStatus = / {print $2; exit}' <<<"${launchctl_output}" 2>/dev/null)"

  if [[ -n "${last_exit}" && "${last_exit}" != "0" ]]; then
    printf 'DEGRADED'
  elif [[ -f "${err_log}" ]] && tail -n 200 "${err_log}" 2>/dev/null | grep -Eiq 'permission denied|no such file|syntax error|traceback|fatal|exit 1|error|failed'; then
    printf 'DEGRADED'
  else
    printf 'SCHEDULED'
  fi
}

disk_summary() {
  # Canonical metric: the user-visible root volume, which matches the
  # operator's normal `df -h /` check during incident response.
  local disk_target="/"
  local percent avail_human oc_size
  percent="$(df -Pk "${disk_target}" 2>/dev/null | awk 'NR==2 {gsub(/%/,"",$5); print $5}')"
  avail_human="$(df -h "${disk_target}" 2>/dev/null | awk 'NR==2 {print $4}')"
  oc_size="$(du -sh "${HOME}/.openclaw" 2>/dev/null | awk '{print $1}')"
  [[ -n "${percent}" ]] || {
    printf 'UNKNOWN'
    return 0
  }

  local detail="${percent}%% used, ${avail_human:-?} avail, openclaw=${oc_size:-?}"
  if (( percent >= 90 )); then
    printf 'FAIL (%s)' "${detail}"
  elif (( percent >= 80 )); then
    printf 'WARN (%s)' "${detail}"
  else
    printf 'OK (%s)' "${detail}"
  fi
}

overall_status() {
  local verify_state="$1"
  local lineage="$2"
  local gateway="$3"
  local sessions="$4"
  local digest="$5"
  local builder="$6"
  local disk="$7"

  if [[ "${gateway}" == FAIL* || "${gateway}" == DOWN* ]]; then
    printf 'FAILED|gateway_failure'
  elif [[ "${digest}" == STALE* ]]; then
    printf 'MEMORY SYSTEM FAILURE|digest=STALE'
  elif [[ "${disk}" == FAIL* ]]; then
    printf 'MEMORY SYSTEM FAILURE|disk=FAIL'
  elif [[ "${builder}" == FAIL* ]]; then
    printf 'MEMORY SYSTEM FAILURE|builder=FAIL'
  elif [[ "${verify_state}" = "MISMATCH" ]]; then
    printf 'DEGRADED|installed_mismatch'
  elif [[ "${lineage}" != "OK" && "${lineage}" != "UNKNOWN" ]]; then
    printf 'DEGRADED|agent_lineage'
  elif [[ "${gateway}" == WARN* ]]; then
    printf 'DEGRADED|gateway=WARN'
  elif [[ "${sessions}" == FANOUT_ANOMALY* || "${sessions}" == HIGH_ACTIVITY* ]]; then
    printf 'DEGRADED|session_store_integrity'
  elif [[ "${builder}" == DEGRADED* ]]; then
    printf 'DEGRADED|builder=DEGRADED'
  elif [[ "${builder}" == MISSING/UNLOADED* ]]; then
    printf 'DEGRADED|builder=MISSING_UNLOADED'
  elif [[ "${sessions}" == HIGH_ACTIVITY* ]]; then
    printf 'DEGRADED|sessions=HIGH_ACTIVITY'
  elif [[ "${sessions}" == FANOUT_ANOMALY* ]]; then
    printf 'DEGRADED|sessions=FANOUT_ANOMALY'
  elif [[ "${disk}" == WARN* ]]; then
    printf 'DEGRADED|disk=WARN'
  else
    printf 'SYSTEM HEALTHY|reason=none'
  fi
}

installed_cli_sha() {
  local installed_path
  installed_path="$(command -v triage 2>/dev/null || true)"
  [[ -n "${installed_path}" ]] || installed_path="${BASH_SOURCE[0]}"
  [[ -f "${installed_path}" ]] || return 1
  sha256_file "${installed_path}"
}

expected_cli_sha() {
  local installed_path manifest

  installed_path="$(command -v triage 2>/dev/null || true)"
  if [[ -n "${installed_path}" && -f "${installed_path}.sha256" ]]; then
    awk '{print $1; exit}' "${installed_path}.sha256"
    return 0
  fi

  manifest="$(find "${SCRIPT_DIR}/../dist" -maxdepth 1 -type f -name 'triage-*.sha256' 2>/dev/null | head -n 1)"
  if [[ -n "${manifest}" && -f "${manifest}" ]]; then
    awk '{print $1; exit}' "${manifest}"
    return 0
  fi

  for manifest in "${SCRIPT_DIR}/../dist/manifest.sha256" "${SCRIPT_DIR}/../SHA256SUMS" "${SCRIPT_DIR}/manifest.sha256"; do
    [[ -f "${manifest}" ]] || continue
    awk '/(bin\/control-plane-triage|triage)$/ {print $1; exit}' "${manifest}"
    return 0
  done

  return 1
}

verify_summary() {
  local installed_sha expected_sha

  installed_sha="$(installed_cli_sha 2>/dev/null || true)"
  expected_sha="$(expected_cli_sha 2>/dev/null || true)"

  if [[ -z "${installed_sha}" || -z "${expected_sha}" ]]; then
    printf '%s|%s|UNKNOWN' "${installed_sha:-unknown}" "${expected_sha:-unknown}"
  elif [[ "${installed_sha}" = "${expected_sha}" ]]; then
    printf '%s|%s|MATCH' "${installed_sha}" "${expected_sha}"
  else
    printf '%s|%s|MISMATCH' "${installed_sha}" "${expected_sha}"
  fi
}

canonical_expected_cli_sha_for_repo() {
  local repo_root="$1"
  local manifest

  for manifest in \
    "${repo_root}/dist/manifest.sha256" \
    "${repo_root}/SHA256SUMS"
  do
    [[ -f "${manifest}" ]] || continue
    awk '/(bin\/control-plane-triage|triage)$/ {print $1; exit}' "${manifest}"
    return 0
  done

  manifest="$(find "${repo_root}/dist" -maxdepth 1 -type f -name '*.sha256' 2>/dev/null | head -n 1)"
  if [[ -n "${manifest}" && -f "${manifest}" ]]; then
    awk '{print $1; exit}' "${manifest}"
    return 0
  fi

  return 1
}

canonical_source_audit() {
  local txt_out="$1"
  local json_out="$2"
  local -a search_roots=("${HOME}" "/usr/local" "/opt")
  local -a repos=()
  local -a marker_repos=()
  local root gitdirs repo_root marker remote writable dirty
  local repo_count=0
  local capped="false"
  local search_timeout="${COLLECT_TIMEOUT}"
  local installed_path installed_sha installed_version
  local canonical_repo=""
  local expected_sha=""
  local verify_state="UNKNOWN"
  local version_match="UNKNOWN"
  local repo_json=""
  local marker_name=""

  for root in "${search_roots[@]}"; do
    [[ -d "${root}" ]] || continue
    while IFS= read -r gitdirs; do
      [[ -n "${gitdirs}" ]] || continue
      repo_root="${gitdirs%/.git}"
      repos+=("${repo_root}")
      repo_count=$((repo_count + 1))
      if (( repo_count >= 200 )); then
        capped="true"
        break 2
      fi
    done < <(run_timeout "${search_timeout}" find "${root}" -maxdepth 4 -name .git -type d 2>/dev/null || true)
  done

  installed_path="$(command -v triage 2>/dev/null || true)"
  installed_sha="$(installed_cli_sha 2>/dev/null || true)"
  installed_version="$("${installed_path:-/usr/bin/false}" --version 2>/dev/null | awk '{print $2; exit}' || true)"

  {
    printf 'canonical_source_audit\n'
    printf 'repos_scanned=%s\n' "${#repos[@]}"
    printf 'repo_cap=200\n'
    printf 'capped=%s\n' "${capped}"
    printf 'installed_cli=%s\n' "${installed_path:-not found}"
    printf 'installed_sha256=%s\n' "${installed_sha:-unknown}"
    printf 'installed_version=%s\n' "${installed_version:-unknown}"
  } > "${txt_out}"

  repo_json='['
  for repo_root in "${repos[@]}"; do
    marker="false"
    marker_name=""
    if [[ -f "${repo_root}/OPENCLAW_CANONICAL_SOURCE.md" ]]; then
      marker="true"
      marker_name="OPENCLAW_CANONICAL_SOURCE.md"
    elif [[ -f "${repo_root}/OPENCLAW_CANONONICAL_SOURCE.md" ]]; then
      marker="true"
      marker_name="OPENCLAW_CANONONICAL_SOURCE.md"
    elif [[ -f "${repo_root}/CANONICAL_REPO" ]]; then
      marker="true"
      marker_name="CANONICAL_REPO"
    fi

    remote="$(run_timeout "${search_timeout}" git -C "${repo_root}" config --get remote.origin.url 2>/dev/null || true)"
    writable="false"
    [[ -w "${repo_root}" ]] && writable="true"

    dirty="unknown"
    if run_timeout "${search_timeout}" git -C "${repo_root}" status --porcelain >/tmp/triage_status.$$ 2>/dev/null; then
      if [[ -s /tmp/triage_status.$$ ]]; then
        dirty="true"
      else
        dirty="false"
      fi
    fi
    rm -f /tmp/triage_status.$$ 2>/dev/null || true

    if [[ "${marker}" = "true" ]]; then
      marker_repos+=("${repo_root}")
      [[ -z "${canonical_repo}" ]] && canonical_repo="${repo_root}"
    fi

    {
      printf '\nrepo=%s\n' "${repo_root}"
      printf 'remote=%s\n' "${remote:-unknown}"
      printf 'marker=%s\n' "${marker}"
      printf 'marker_name=%s\n' "${marker_name:-none}"
      printf 'writable=%s\n' "${writable}"
      printf 'dirty=%s\n' "${dirty}"
    } >> "${txt_out}"

    [[ "${repo_json}" != "[" ]] && repo_json+=","
    repo_json+="{\"repo_root\":\"$(json_escape "${repo_root}")\",\"remote\":\"$(json_escape "${remote:-unknown}")\",\"marker\":${marker},\"marker_name\":\"$(json_escape "${marker_name:-none}")\",\"writable\":${writable},\"dirty\":\"$(json_escape "${dirty}")\"}"
  done
  repo_json+=']'

  if [[ -n "${canonical_repo}" ]]; then
    expected_sha="$(canonical_expected_cli_sha_for_repo "${canonical_repo}" 2>/dev/null || true)"
    if [[ -n "${expected_sha}" && -n "${installed_sha}" ]]; then
      if [[ "${expected_sha}" = "${installed_sha}" ]]; then
        verify_state="MATCH"
      else
        verify_state="MISMATCH"
      fi
    else
      local canonical_version=""
      canonical_version="$(tr -d '[:space:]' < "${canonical_repo}/VERSION" 2>/dev/null || true)"
      if [[ -n "${canonical_version}" && -n "${installed_version}" ]]; then
        if [[ "${canonical_version}" = "${installed_version}" ]]; then
          version_match="MATCH"
        else
          version_match="MISMATCH"
        fi
      fi
    fi
  fi

  {
    printf '\ncanonical_repo=%s\n' "${canonical_repo:-not found}"
    printf 'canonical_expected_sha256=%s\n' "${expected_sha:-unknown}"
    printf 'installed_vs_canonical=%s\n' "${verify_state}"
    printf 'version_fallback=%s\n' "${version_match}"
  } >> "${txt_out}"

  cat > "${json_out}" <<EOF
{"repos_scanned":${#repos[@]},"repo_cap":200,"capped":${capped},"installed_cli":"$(json_escape "${installed_path:-not found}")","installed_sha256":"$(json_escape "${installed_sha:-unknown}")","installed_version":"$(json_escape "${installed_version:-unknown}")","canonical_repo":"$(json_escape "${canonical_repo:-not found}")","canonical_expected_sha256":"$(json_escape "${expected_sha:-unknown}")","installed_vs_canonical":"$(json_escape "${verify_state}")","version_fallback":"$(json_escape "${version_match}")","repos":${repo_json}}
EOF
}

render_operator_brief() {
  local bundle_dir="$1"
  local gateway sessions digest builder disk status verify_status status_with_reason reason verify_installed_sha verify_expected_sha lineage status_token

  gateway="$(gateway_summary "${bundle_dir}")"
  sessions="$(sessions_summary "${bundle_dir}")"
  lineage="$(lineage_summary "${bundle_dir}")"
  digest="$(digest_summary)"
  builder="$(builder_summary)"
  disk="$(disk_summary)"
  verify_status="$(verify_summary)"
  verify_installed_sha="${verify_status%%|*}"
  verify_status="${verify_status#*|}"
  verify_expected_sha="${verify_status%%|*}"
  verify_status="${verify_status##*|}"
  status_with_reason="$(overall_status "${verify_status}" "${lineage}" "${gateway}" "${sessions}" "${digest}" "${builder}" "${disk}")"
  status="${status_with_reason%%|*}"
  reason="${status_with_reason#*|}"
  case "${status}" in
    SYSTEM\ HEALTHY)
      status_token="HEALTHY"
      ;;
    DEGRADED)
      status_token="DEGRADED"
      ;;
    *)
      status_token="FAILED"
      ;;
  esac

  printf '%s\n' "$(color_wrap '1;36' 'OpenClaw System Triage')"
  printf 'Evidence bundle: %s\n' "${bundle_dir}"
  render_signal_line "gateway" "${gateway}"
  render_signal_line "sessions" "${sessions}"
  render_signal_line "digest" "${digest}"
  render_signal_line "builder" "${builder}"
  render_signal_line "disk" "${disk}"
  if ui_enabled; then
    case "${verify_status}" in
      MATCH)
        printf 'verify: installed_sha=%s expected_sha=%s %s\n' "${verify_installed_sha:0:8}" "${verify_expected_sha:0:8}" "$(color_wrap '32' "${verify_status}")"
        ;;
      MISMATCH)
        printf 'verify: installed_sha=%s expected_sha=%s %s\n' "${verify_installed_sha:0:8}" "${verify_expected_sha:0:8}" "$(color_wrap '31' "${verify_status}")"
        ;;
      *)
        printf 'verify: installed_sha=%s expected_sha=%s %s\n' "${verify_installed_sha:0:8}" "${verify_expected_sha:0:8}" "$(color_wrap '90' "${verify_status}")"
        ;;
    esac
  else
    printf 'verify: installed_sha=%s expected_sha=%s %s\n' "${verify_installed_sha:0:8}" "${verify_expected_sha:0:8}" "${verify_status}"
  fi
  if ui_enabled; then
    case "${status_token}" in
      FAILED)
        printf '%s %s (%s)\n' "$(color_wrap '1;31' 'STATUS:')" "$(color_wrap '1;31' "[${status_token}]")" "${reason}"
        ;;
      DEGRADED)
        printf '%s %s (%s)\n' "$(color_wrap '1;33' 'STATUS:')" "$(color_wrap '1;33' "[${status_token}]")" "${reason}"
        ;;
      *)
        if [[ "${reason}" = "reason=none" ]]; then
          printf '%s %s\n' "$(color_wrap '1;32' 'STATUS:')" "$(color_wrap '1;32' "[${status_token}]")"
        else
          printf '%s %s (%s)\n' "$(color_wrap '1;32' 'STATUS:')" "$(color_wrap '1;32' "[${status_token}]")" "${reason}"
        fi
        ;;
    esac
  else
    if [[ "${reason}" = "reason=none" ]]; then
      printf 'STATUS: [%s]\n' "${status_token}"
    else
      printf 'STATUS: [%s] (%s)\n' "${status_token}" "${reason}"
    fi
  fi

  # ── OpenClaw Observe section ──────────────────────────────────────────────
  local _obs_snap="${HOME}/.openclaw/workspace/reports/observe_snapshot.json"
  local _obs_agents="-" _obs_sessions="-" _obs_orphans="-"
  local _obs_alerts="-" _obs_gw="-" _obs_score="-" _obs_state="-"

  if command -v python3 >/dev/null 2>&1 && [[ -f "${_obs_snap}" ]]; then
    # Run aggregator first to refresh (non-blocking, exits 0)
    python3 "${HOME}/.openclaw/watchdog/observe_aggregator.py" >/dev/null 2>&1 || true
    # Parse snapshot
    _obs_agents=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('agents','-'))" 2>/dev/null || echo "-")
    _obs_sessions=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('sessions','-'))" 2>/dev/null || echo "-")
    _obs_orphans=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('orphan_sessions','-'))" 2>/dev/null || echo "-")
    _obs_alerts=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('runtime_alerts','-'))" 2>/dev/null || echo "-")
    _obs_gw=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('gateway_warnings','-'))" 2>/dev/null || echo "-")
    _obs_score=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('reliability_score','-'))" 2>/dev/null || echo "-")
    _obs_state=$(python3 -c "import json; d=json.load(open('${_obs_snap}')); print(d.get('protection_state','-'))" 2>/dev/null || echo "-")
  elif [[ ! -f "${_obs_snap}" ]]; then
    # Try to generate snapshot on-demand
    python3 "${HOME}/.openclaw/watchdog/observe_aggregator.py" >/dev/null 2>&1 || true
  fi

  printf '\n'
  if ui_enabled; then
    printf '%s\n' "$(color_wrap '1;36' 'OpenClaw Observe')"
  else
    printf 'OpenClaw Observe\n'
  fi
  printf 'agents: %s\n'           "${_obs_agents}"
  printf 'sessions: %s\n'         "${_obs_sessions}"
  printf 'orphan sessions: %s\n'  "${_obs_orphans}"
  printf 'runtime alerts: %s\n'   "${_obs_alerts}"
  printf 'gateway warnings: %s\n' "${_obs_gw}"
  printf 'reliability score: %s\n' "${_obs_score}"
  if ui_enabled; then
    case "${_obs_state}" in
      ACTIVE)
        printf 'protection state: %s\n' "$(color_wrap '1;32' "${_obs_state}")" ;;
      DEGRADED)
        printf 'protection state: %s\n' "$(color_wrap '1;33' "${_obs_state}")" ;;
      AT_RISK)
        printf 'protection state: %s\n' "$(color_wrap '1;31' "${_obs_state}")" ;;
      *)
        printf 'protection state: %s\n' "${_obs_state}" ;;
    esac
  else
    printf 'protection state: %s\n' "${_obs_state}"
  fi
}

print_help() {
  # SAFE: Prints local help text only; does not inspect services, mutate config, or access the network.
  cat <<'EOF'
Triage safety guarantees
  - Read-only: never modifies system state
  - No telemetry: zero outbound calls
  - Local-only: all execution on the operator machine
  - Proof bundle output: ~/triage-bundles/ only
  - Auditable source: cat "$(command -v triage)"

Usage:
  triage
  triage --help
  triage --version
  triage --self-test
  triage --color=auto|always|never

Deprecated aliases:
  OCTriage
  octriageunit

Behavior:
  - verifies required local tools are present
  - creates a timestamped proof bundle directory
  - collects real evidence: doctor output, gateway logs, launchctl snapshots
  - always exits 0; degraded signals are captured as evidence
EOF
}

print_alias_notice_if_needed() {
  case "${INVOKED_NAME}" in
    OCTriage|octriageunit)
      printf 'Deprecated, use `triage`\n' >&2
      ;;
  esac
}

check_env() {
  # SAFE: Checks only for local command availability; does not execute launchctl, openclaw, or any network operation.
  local missing=0
  local tool

  for tool in launchctl openclaw; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
      printf 'Environment signal: degraded — required tool not found: %s\n' "${tool}" >&2
      missing=1
    fi
  done

  return "${missing}"
}

# SAFE: Runs a command with a timeout; captures stdout+stderr to a file.
# Never restarts services, never modifies config.
collect() {
  local label="$1"
  local outfile="$2"
  shift 2

  if run_timeout "${COLLECT_TIMEOUT}" "$@" > "${outfile}" 2>&1; then
    printf '  [ok]     %s\n' "${label}"
  else
    local exit_code=$?
    if [[ -z "$(cat "${outfile}" 2>/dev/null)" ]]; then
      printf 'TIMED OUT after %ss\n' "${COLLECT_TIMEOUT}" >> "${outfile}"
      printf '  [timeout] %s\n' "${label}"
    else
      printf '  [degraded] %s (exit %d)\n' "${label}" "${exit_code}"
    fi
  fi
}

collect_log_window() {
  local logfile="$1"
  local outfile="$2"
  local filtered="${3:-0}"

  [[ -f "${logfile}" ]] || return 1

  if [[ "${filtered}" = "1" ]]; then
    if run_timeout "${COLLECT_TIMEOUT}" bash -lc 'tail -n 2000 "$1" | head -n 200 | grep -Ei "password_missing|unauthorized|failed|error|timeout|nonce|1006|1008|funnel|tailscale" || tail -n 2000 "$1" | head -n 200' _ "${logfile}" > "${outfile}" 2>/dev/null; then
      return 0
    fi
  else
    if run_timeout "${COLLECT_TIMEOUT}" bash -lc 'tail -n 2000 "$1" | head -n 200' _ "${logfile}" > "${outfile}" 2>/dev/null; then
      return 0
    fi
  fi

  printf 'timeout\n' > "${outfile}"
  return 0
}

collect_session_topology() {
  local outfile="$1"
  local sessions_root="${HOME}/.openclaw/agents"
  local cli_json="${BUNDLE_ROOT}/.sessions_cli_$$.json"
  local agents=0
  local total=0
  local recent=0
  local orphan=0
  local active="unknown"
  local classification="UNKNOWN"
  local agent_lineage="UNKNOWN"
  local max_children=0
  local parent child pair_count
  local agent_dir sessions_dir agent_name transcript ref_file session_file ref_count

  [[ -d "${sessions_root}" ]] || {
    cat > "${outfile}" <<EOF
classification: UNKNOWN
agents: 0
active_sessions: unknown
sessions_total: 0
sessions_recent: 0
orphan_transcripts: 0
agent_lineage: UNKNOWN
max_context_usage: unknown
EOF
    return 0
  }

  if run_timeout "${SESSIONS_TIMEOUT}" openclaw sessions -json > "${cli_json}" 2>/dev/null; then
    active="$(grep -Eo '"(session_id|sessionId|id)"' "${cli_json}" 2>/dev/null | wc -l | tr -d ' ')"
    [[ -n "${active}" ]] || active="unknown"
    max_children="$(grep -Eo '"parent(Id|_id)"[[:space:]]*:[[:space:]]*"[^"]+"' "${cli_json}" 2>/dev/null | sed -E 's/.*"([^"]+)"$/\1/' | sort | uniq -c | awk 'BEGIN{m=0} {if ($1>m) m=$1} END{print m+0}')"
    if grep -Eq '"(id|sessionId|session_id)"[[:space:]]*:[[:space:]]*"([^"]+)".*"parent(Id|_id)"[[:space:]]*:[[:space:]]*"\2"' "${cli_json}" 2>/dev/null; then
      agent_lineage="LOOP"
    elif grep -Eq '"parent(Id|_id)"[[:space:]]*:[[:space:]]*"[^"]+"' "${cli_json}" 2>/dev/null && ! grep -Eq '"(id|sessionId|session_id)"[[:space:]]*:[[:space:]]*"[^"]+"' "${cli_json}" 2>/dev/null; then
      agent_lineage="BROKEN"
    elif grep -Eq '"parent(Id|_id)"[[:space:]]*:[[:space:]]*"[^"]+"' "${cli_json}" 2>/dev/null; then
      while IFS= read -r parent; do
        [[ -n "${parent}" ]] || continue
        if ! grep -Fq "\"${parent}\"" "${cli_json}" 2>/dev/null; then
          agent_lineage="BROKEN"
          break
        fi
      done < <(grep -Eo '"parent(Id|_id)"[[:space:]]*:[[:space:]]*"[^"]+"' "${cli_json}" 2>/dev/null | sed -E 's/.*"([^"]+)"$/\1/' | sort -u)
      if [[ "${agent_lineage}" = "UNKNOWN" || "${agent_lineage}" = "OK" ]]; then
        if (( max_children > 10 )); then
          agent_lineage="FANOUT (children>10)"
        else
          agent_lineage="OK"
        fi
      fi
    else
      agent_lineage="OK"
    fi
  fi

  # Count sessions using index files (fast) — avoid walking .jsonl files
  # agents = number of agent dirs with a sessions.json
  # total  = sum of keys in each sessions.json (each key = one session)
  # recent = sessions with updatedAt in last 60 min (mtime proxy via find)
  # orphan = files in _orphaned_sessions dir
  agents="$(find "${sessions_root}" -mindepth 2 -maxdepth 2 -name 'sessions.json' 2>/dev/null | wc -l | tr -d ' ')"
  total="$(find "${sessions_root}" -mindepth 2 -maxdepth 2 -name 'sessions.json' -exec grep -c '"updatedAt"' {} \; 2>/dev/null | awk '{s+=$1} END{print s+0}')"
  recent="$(find "${sessions_root}" -mindepth 3 -maxdepth 3 -name '*.jsonl' -mmin -60 -not -name 'sessions.json' 2>/dev/null | wc -l | tr -d ' ')"
  orphan="$(find "${sessions_root}/_orphaned_sessions" -maxdepth 1 -name '*.jsonl' 2>/dev/null | wc -l | tr -d ' ')"

  # orphan count is informational only — does not drive classification (Archer verdict 2026-04-13)
  if (( total > 50 )); then
    classification="FANOUT_ANOMALY"
  elif (( recent > 10 )); then
    classification="HIGH_ACTIVITY"
  elif (( agents > 0 )); then
    classification="NORMAL"
  fi

  cat > "${outfile}" <<EOF
classification: ${classification}
agents: ${agents}
active_sessions: ${active}
sessions_total: ${total}
sessions_recent: ${recent}
orphan_transcripts: ${orphan}
agent_lineage: ${agent_lineage}
max_context_usage: unknown
EOF

  rm -f "${cli_json}" 2>/dev/null || true
}

proof_bundle() {
  local timestamp bundle_dir status_dir collector_file collector_status_file
  local -a collector_pids=()
  timestamp="$(date +%Y%m%d-%H%M%S)"
  bundle_dir="${BUNDLE_ROOT}/${timestamp}"
  status_dir="${bundle_dir}/.collector-status"

  mkdir -p "${bundle_dir}" || {
    printf 'Environment signal: degraded — could not create bundle directory: %s\n' "${bundle_dir}" >&2
    return 1
  }
  mkdir -p "${status_dir}" || return 1
  : > "${bundle_dir}/collector_debug.log"

  # ── bundle_summary.txt (always written first) ───────────────────────────────
  cat >"${bundle_dir}/bundle_summary.txt" <<EOF
Triage Proof Bundle
Version: $(cat "${VERSION_FILE}" 2>/dev/null || echo "${EMBEDDED_VERSION}")
Mode: read-only snapshot
Generated: ${timestamp}
Host: $(hostname)
User: $(id -un)
EOF

  [[ "${OCTU_SHARE_MODE:-0}" != "1" ]] && printf 'Collecting evidence...\n'

  for collector_file in "${COLLECTOR_DIR}"/*.sh; do
    [[ -f "${collector_file}" ]] || continue
    collector_status_file="${status_dir}/$(basename "${collector_file}" .sh).status"
    (
      collector_output_file="${status_dir}/$(basename "${collector_file}" .sh).out"
      unset COLLECTOR_ID COLLECTOR_LABEL
      unset COLLECTOR_META_COMMAND COLLECTOR_META_EXIT_CODE COLLECTOR_META_TIMED_OUT
      unset COLLECTOR_META_BYTES_CAPTURED COLLECTOR_META_CONFIDENCE COLLECTOR_META_ARTIFACT_STATE
      unset COLLECTOR_META_RESULT_STATE
      unset -f collector_run 2>/dev/null || true
      source "${collector_file}"
      collector_run "${bundle_dir}" > "${collector_output_file}"
      collector_rc=$?
      cat "${collector_output_file}"
      rm -f "${collector_output_file}" 2>/dev/null || true
      octu_write_collector_metadata_file \
        "${status_dir}/$(basename "${collector_file}" .sh).meta.json" \
        "${COLLECTOR_ID:-$(basename "${collector_file}" .sh)}" \
        "${collector_file}" \
        "${COLLECTOR_META_COMMAND:-$(basename "${collector_file}" .sh)}" \
        "${COLLECTOR_META_EXIT_CODE:-${collector_rc}}" \
        "${COLLECTOR_META_TIMED_OUT:-false}" \
        "${COLLECTOR_META_BYTES_CAPTURED:-0}" \
        "${COLLECTOR_META_CONFIDENCE:-LOW}" \
        "${COLLECTOR_META_ARTIFACT_STATE:-LOW_CONFIDENCE}" \
        "${COLLECTOR_META_RESULT_STATE:-UNKNOWN}"
      exit "${collector_rc}"
    ) > "${collector_status_file}" 2>> "${bundle_dir}/collector_debug.log" &
    collector_pids+=($!)
  done

  if ((${#collector_pids[@]} > 0)); then
    for pid in "${collector_pids[@]}"; do
      wait "${pid}" 2>/dev/null || true
    done
  fi

  cat "${status_dir}"/*.status > "${bundle_dir}/collector_status.txt" 2>/dev/null || true
  cat "${status_dir}"/*.meta.json > "${bundle_dir}/collector_metadata.jsonl" 2>/dev/null || true

  # ── manifest.sha256 ─────────────────────────────────────────────────────────
  if command -v shasum >/dev/null 2>&1; then
    (
      cd "${bundle_dir}" || exit 1
      shasum -a 256 ./* 2>/dev/null > manifest.sha256
    ) || true
  else
    printf 'SHA256 manifest unavailable: shasum not found.\n' > "${bundle_dir}/manifest.sha256"
  fi

  source "${STATUS_REDUCER}"
  if [[ "${OCTU_SHARE_MODE:-0}" == "1" ]]; then
    octu_render_share_snapshot "${bundle_dir}"
  else
    printf 'Proof bundle initialized at %s\n' "${bundle_dir}"
    octu_render_from_statuses "${bundle_dir}" "${bundle_dir}/collector_status.txt"
  fi
}

main() {
  print_alias_notice_if_needed

  # Fast-path: share mode
  local _share=0 _redact=0 _copy=0
  for _arg in "$@"; do
    case "${_arg}" in
      -share|--share)   _share=1 ;;
      -redact|--redact) _redact=1 ;;
      -copy|--copy)     _copy=1 ;;
    esac
  done
  if ((_share)); then
    export OCTU_SHARE_MODE=1
    export OCTU_SHARE_REDACT="${_redact}"
    if ((_copy)) && command -v pbcopy >/dev/null 2>&1; then
      local _snap
      _snap="$(proof_bundle 2>/dev/null)"
      printf '%s\n' "${_snap}"
      printf '%s\n' "${_snap}" | pbcopy
      printf '(copied to clipboard)\n' >&2
    else
      proof_bundle 2>/dev/null
      if ((_copy)); then
        printf '(pbcopy not available; output not copied)\n' >&2
      fi
    fi
    return 0
  fi

  # Fast-path: watch mode — available in Acme commercial edition
  local _interval=10
  for _arg in "$@"; do
    case "${_arg}" in
      -watch|--watch)
        printf 'Live watch mode is available in Triage for Acme — https://acmeagentsupply.com\n' >&2
        return 1
        return 0
        ;;
    esac
  done

  while (($# > 0)); do
    case "${1-}" in
      --help|-help|-h)
        print_help
        return 0
        ;;
      --version|-version)
        local ver
        ver="$(cat "${VERSION_FILE}" 2>/dev/null || echo "${EMBEDDED_VERSION}")"
        printf 'triage %s\n' "${ver}"
        return 0
        ;;
      --self-test|-self-test)
        printf 'Self-test: checking syntax and flags...\n'
        bash -n "${BASH_SOURCE[0]}" && printf '  ✓ syntax OK\n'
        printf '  ✓ --version: %s\n' "$(cat "${VERSION_FILE}" 2>/dev/null || echo "${EMBEDDED_VERSION}")"
        printf '  ✓ --help: ' && print_help | grep -q "Read-only" && printf 'safety guarantees present\n'
        printf '  ✓ collect timeout: %ss\n' "${COLLECT_TIMEOUT}"
        printf '  ✓ color mode: %s\n' "${OCTU_COLOR_MODE}"
        printf 'Self-test PASSED\n'
        return 0
        ;;
      --color=auto|--color=always|--color=never)
        OCTU_COLOR_MODE="${1#--color=}"
        ;;
      "")
        ;;
      *)
        printf 'Unknown argument: %s\n\n' "${1}" >&2
        print_help >&2
        return 2
        ;;
    esac
    shift
  done

  check_env || true   # degraded env captured in bundle; never block exit 0

  proof_bundle || {
    printf 'Gateway probe: unhealthy — could not initialize proof bundle.\n' >&2
    return 1
  }

  return 0
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
