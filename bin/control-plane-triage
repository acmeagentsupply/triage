#!/usr/bin/env bash

# OCTriageUnit control-plane triage entrypoint
# READ-ONLY MODE: this script must not modify system configuration or service state.
# NO NETWORK CALLS: this script must not initiate outbound network activity or telemetry.
# NO CONFIG MUTATION: this script must not write outside ~/octriage-bundles/ proof artifacts.
#
# Safety: read-only • no network • no config writes

set -u

readonly BUNDLE_ROOT="${HOME}/octriage-bundles"
readonly SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
readonly VERSION_FILE="${SCRIPT_DIR}/../VERSION"
readonly EMBEDDED_VERSION="0.1.3"   # injected at install time if standalone
readonly COLLECT_TIMEOUT=12         # seconds; applied to each slow command

# Ensure standard tool paths are available (macOS + Homebrew)
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:${PATH}"

# macOS-compatible timeout wrapper (timeout(1) is GNU coreutils, not in base macOS)
run_timeout() {
  local secs="$1"; shift
  "$@" &
  local child=$!
  ( sleep "${secs}" && kill -TERM "${child}" 2>/dev/null ) &
  local watcher=$!
  wait "${child}" 2>/dev/null
  local rc=$?
  kill "${watcher}" 2>/dev/null
  wait "${watcher}" 2>/dev/null
  return "${rc}"
}

print_help() {
  # SAFE: Prints local help text only; does not inspect services, mutate config, or access the network.
  cat <<'EOF'
OCTriageUnit safety guarantees
  - Read-only: never modifies system state
  - No telemetry: zero outbound calls
  - Local-only: all execution on the operator machine
  - Proof bundle output: ~/octriage-bundles/ only
  - Auditable source: cat bin/control-plane-triage

Usage:
  bin/control-plane-triage
  bin/control-plane-triage --help
  bin/control-plane-triage --version
  bin/control-plane-triage --self-test

Behavior:
  - verifies required local tools are present
  - creates a timestamped proof bundle directory
  - collects real evidence: doctor output, gateway logs, launchctl snapshots
  - always exits 0; degraded signals are captured as evidence
EOF
}

check_env() {
  # SAFE: Checks only for local command availability; does not execute launchctl, openclaw, or any network operation.
  local missing=0
  local tool

  for tool in launchctl openclaw; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
      printf 'Environment signal: degraded — required tool not found: %s\n' "${tool}" >&2
      missing=1
    fi
  done

  return "${missing}"
}

# SAFE: Runs a command with a timeout; captures stdout+stderr to a file.
# Never restarts services, never modifies config.
collect() {
  local label="$1"
  local outfile="$2"
  shift 2

  if run_timeout "${COLLECT_TIMEOUT}" "$@" > "${outfile}" 2>&1; then
    printf '  [ok]     %s\n' "${label}"
  else
    local exit_code=$?
    if [[ -z "$(cat "${outfile}" 2>/dev/null)" ]]; then
      printf 'TIMED OUT after %ss\n' "${COLLECT_TIMEOUT}" >> "${outfile}"
      printf '  [timeout] %s\n' "${label}"
    else
      printf '  [degraded] %s (exit %d)\n' "${label}" "${exit_code}"
    fi
  fi
}

proof_bundle() {
  local timestamp bundle_dir
  timestamp="$(date +%Y%m%d-%H%M%S)"
  bundle_dir="${BUNDLE_ROOT}/${timestamp}"

  mkdir -p "${bundle_dir}" || {
    printf 'Environment signal: degraded — could not create bundle directory: %s\n' "${bundle_dir}" >&2
    return 1
  }

  # ── bundle_summary.txt (always written first) ───────────────────────────────
  cat >"${bundle_dir}/bundle_summary.txt" <<EOF
OCTriageUnit Proof Bundle
Version: $(cat "${VERSION_FILE}" 2>/dev/null || echo "${EMBEDDED_VERSION}")
Mode: read-only snapshot
Generated: ${timestamp}
Host: $(hostname)
User: $(id -un)
EOF

  printf 'Collecting evidence...\n'

  # ── doctor_output.txt ───────────────────────────────────────────────────────
  # SAFE: read-only diagnostic; never calls --fix or restarts anything
  # Uses longer timeout (25s) as doctor probes all components
  local doctor_timeout=25
  if run_timeout "${doctor_timeout}" openclaw doctor > "${bundle_dir}/doctor_output.txt" 2>&1; then
    printf '  [ok]     openclaw doctor\n'
  else
    printf '  [degraded] openclaw doctor (captured partial output)\n'
  fi

  # ── gateway_err_tail.txt ────────────────────────────────────────────────────
  # SAFE: reads log file only; no writes outside bundle
  local err_log="${HOME}/.openclaw/ops/logs/gateway.err.log"
  if [[ -f "${err_log}" ]]; then
    {
      tail -n 250 "${err_log}" \
        | grep -Ei "password_missing|unauthorized|failed|error|timeout|nonce|1006|1008|funnel|tailscale" \
        || tail -n 250 "${err_log}"
    } > "${bundle_dir}/gateway_err_tail.txt" 2>/dev/null
    printf '  [ok]     gateway_err_tail\n'
  else
    printf 'gateway.err.log not found at %s\n' "${err_log}" > "${bundle_dir}/gateway_err_tail.txt"
    printf '  [missing] gateway_err_tail\n'
  fi

  # ── gateway_log_tail.txt ────────────────────────────────────────────────────
  local gw_log="${HOME}/.openclaw/ops/logs/gateway.log"
  if [[ -f "${gw_log}" ]]; then
    tail -n 120 "${gw_log}" > "${bundle_dir}/gateway_log_tail.txt" 2>/dev/null
    printf '  [ok]     gateway_log_tail\n'
  else
    printf 'gateway.log not found at %s\n' "${gw_log}" > "${bundle_dir}/gateway_log_tail.txt"
    printf '  [missing] gateway_log_tail\n'
  fi

  # ── openclaw_status.txt ─────────────────────────────────────────────────────
  # SAFE: status commands only; no --fix, no restart
  {
    printf '=== openclaw status ===\n'
    run_timeout "${COLLECT_TIMEOUT}" openclaw status 2>&1 || printf 'TIMED OUT or FAILED\n'
    printf '\n=== openclaw gateway status --deep ===\n'
    run_timeout "${COLLECT_TIMEOUT}" openclaw gateway status --deep 2>&1 || printf 'TIMED OUT or FAILED\n'
  } > "${bundle_dir}/openclaw_status.txt"
  printf '  [ok]     openclaw_status\n'

  # ── launchctl_gateway.txt ───────────────────────────────────────────────────
  # SAFE: print only; does not start/stop/restart services
  collect "launchctl gateway" \
    "${bundle_dir}/launchctl_gateway.txt" \
    launchctl print "gui/$(id -u)/ai.openclaw.gateway"

  # ── launchctl_watchdog.txt ──────────────────────────────────────────────────
  if launchctl print "gui/$(id -u)/ai.openclaw.hendrik_watchdog" >/dev/null 2>&1; then
    collect "launchctl watchdog" \
      "${bundle_dir}/launchctl_watchdog.txt" \
      launchctl print "gui/$(id -u)/ai.openclaw.hendrik_watchdog"
  else
    printf 'Service not registered: ai.openclaw.hendrik_watchdog\n' \
      > "${bundle_dir}/launchctl_watchdog.txt"
    printf '  [skipped] launchctl watchdog (not registered)\n'
  fi

  # ── gateway_health.txt + gateway_health.json ────────────────────────────────
  # SAFE: copy only; healthcheck agent writes these files independently
  local gw_health_dir="${HOME}/openclaw/health"
  if [[ -f "${gw_health_dir}/gateway_health.txt" ]]; then
    cp "${gw_health_dir}/gateway_health.txt" "${bundle_dir}/gateway_health.txt" 2>/dev/null || true
    cp "${gw_health_dir}/gateway_health.json" "${bundle_dir}/gateway_health.json" 2>/dev/null || true
    printf 'Gateway health snapshot included.\n'
  else
    printf 'SKIPPED: gateway_health files not found (healthcheck agent not running?)\n' \
      > "${bundle_dir}/gateway_health.txt"
    printf '  [skipped] gateway_health\n'
  fi

  # ── manifest.sha256 ─────────────────────────────────────────────────────────
  if command -v shasum >/dev/null 2>&1; then
    (
      cd "${bundle_dir}" || exit 1
      shasum -a 256 ./* 2>/dev/null > manifest.sha256
    ) || true
  else
    printf 'SHA256 manifest unavailable: shasum not found.\n' > "${bundle_dir}/manifest.sha256"
  fi

  printf 'Proof bundle initialized at %s\n' "${bundle_dir}"
}

main() {
  case "${1-}" in
    --help|-help|-h)
      print_help
      return 0
      ;;
    --version|-version)
      local ver
      ver="$(cat "${VERSION_FILE}" 2>/dev/null || echo "${EMBEDDED_VERSION}")"
      printf 'octriageunit %s\n' "${ver}"
      return 0
      ;;
    --self-test|-self-test)
      printf 'Self-test: checking syntax and flags...\n'
      bash -n "${BASH_SOURCE[0]}" && printf '  ✓ syntax OK\n'
      printf '  ✓ --version: %s\n' "$(cat "${VERSION_FILE}" 2>/dev/null || echo "${EMBEDDED_VERSION}")"
      printf '  ✓ --help: ' && print_help | grep -q "Read-only" && printf 'safety guarantees present\n'
      printf '  ✓ collect timeout: %ss\n' "${COLLECT_TIMEOUT}"
      printf 'Self-test PASSED\n'
      return 0
      ;;
    "")
      ;;
    *)
      printf 'Unknown argument: %s\n\n' "${1}" >&2
      print_help >&2
      return 2
      ;;
  esac

  check_env || true   # degraded env captured in bundle; never block exit 0

  proof_bundle || {
    printf 'Gateway probe: unhealthy — could not initialize proof bundle.\n' >&2
    return 1
  }

  return 0
}

main "$@"
